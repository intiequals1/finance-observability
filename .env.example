# SEC EDGAR — no API key required. Provide a descriptive User-Agent per SEC policy.
SEC_USER_AGENT=finance-observability your-email@example.com

# Tickers to load (comma-separated, must be in TICKER_CIK map in app.py)
COMPANIES=AAPL,MSFT,AMZN

# ETL reload interval in seconds (default: 1 hour)
LOAD_INTERVAL_SECONDS=3600

# PostgreSQL — change ALL three values before any non-local deployment
POSTGRES_DB=finance
POSTGRES_USER=finance
POSTGRES_PASSWORD=finance

# Grafana — change before any non-local deployment
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# WARNING: These defaults are for local development only.
# Never commit a .env file with real credentials to version control.
