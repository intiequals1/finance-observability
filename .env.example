# Finance Observability local configuration

# SEC requests should include a descriptive user agent.
# Example: FinanceObservability/0.1 your.email@example.com
SEC_USER_AGENT=FinanceObservability/0.1 local@example.com

# Local service ports
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=finance_observability
POSTGRES_USER=finance
POSTGRES_PASSWORD=finance

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

PROMETHEUS_PORT=9090
ETL_PORT=8000
